# Full GHCR image name, lower-case owner/repo
IMAGE_NAME=ghcr.io/owner/repo

# Image tag to deploy in Portainer
IMAGE_TAG=latest

# Container listening port (inside and outside)
PORT=5173

# Path inside container where MOHAA files are mounted
MOHAA_BASE_PATH=/data/mohaa

# Host machine path to your MOHAA files
MOHAA_HOST_PATH=/absolute/path/to/your/mohaa-files
